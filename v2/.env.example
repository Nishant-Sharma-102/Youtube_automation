# Copy to .env (or reuse the parent ../.env). NEVER commit real secrets.
# Config loads ../.env first, then a local .env override if present.

# --- Content generation ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Fallback when Gemini has no key / hits its daily quota:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Voice ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_MONTHLY_LIMIT=10000
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=en-US-Neural2-F

# --- YouTube (Data API v3, OAuth2) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_REDIRECT_URI=http://localhost:5757/oauth2callback
YOUTUBE_MOCK=0

# --- Publishing / notifications ---
# Cron publish privacy. Keep 'private' until you confirm quality, then 'public'.
PUBLISH_PRIVACY=private
# Optional Telegram publish confirmations:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Render (Phase 3, on the box that has Blender) ---
RHUBARB_BIN=rhubarb
MIXAMO_CLIPS_DIR=./assets/mixamo
RENDER_FPS=24

# --- Database ---
V2_DB_PATH=./data/queue.db
