{
  "name": "giggle-grove-content-gen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Content-generation stage for the Giggle Grove kids animation channel (Gemini script + metadata generator).",
  "scripts": {
    "db:init": "tsx src/db/init.ts",
    "generate": "tsx src/generate.ts",
    "publish": "tsx src/orchestrate/publish.ts",
    "voice": "tsx src/voice/generate-voice.ts",
    "attach": "tsx src/attach.ts",
    "set-privacy": "tsx src/set-privacy.ts",
    "captions": "tsx src/captions/generate-captions.ts",
    "youtube:auth": "tsx src/mcp/get-refresh-token.ts",
    "youtube:server": "tsx src/mcp/youtube-server.ts",
    "dev": "tsx watch src/generate.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@google/genai": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.3.0",
    "googleapis": "^144.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
