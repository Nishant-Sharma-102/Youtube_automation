# Copy this file to `.env` and fill in real values there.
# `.env` is git-ignored; THIS template must never contain real secrets.

# --- Gemini (content generation) ---
# Get a free-tier key from Google AI Studio: https://aistudio.google.com/app/apikey
# PLACEHOLDER ONLY — never put a real key in this committed template. Put the real
# value in .env (git-ignored). The key that was previously here MUST be rotated.
GEMINI_API_KEY=

# Brief-recommended model for this volume (free tier). Change only if you know why.
GEMINI_MODEL=gemini-2.5-flash

# --- Claude / Anthropic (fallback for text generation when Gemini is unavailable) ---
# Get a key at https://console.anthropic.com/. Used only if Gemini has no key or hits quota.
ANTHROPIC_API_KEY=
# Default is the most capable model. For this high-volume task you may prefer a cheaper
# tier: claude-haiku-4-5 (cheapest) or claude-sonnet-5 (balanced).
CLAUDE_MODEL=claude-opus-4-8

# --- Content queue database ---
# Only 'sqlite' is implemented today. Interface is ready for 'postgres'/'mysql' later.
DB_DRIVER=sqlite
# Path to the SQLite database file (created on `npm run db:init`).
DB_PATH=./data/content-queue.db

# --- YouTube publishing (Data API v3, OAuth2) ---
# From your Google Cloud project's OAuth 2.0 client (Desktop app type recommended).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Obtained once by running `npm run youtube:auth` (do NOT commit the real value).
YOUTUBE_REFRESH_TOKEN=
# Redirect URI used only by the one-time auth helper (must be an authorized URI on the client).
YOUTUBE_REDIRECT_URI=http://localhost:5757/oauth2callback
# Set to 1 to run the MCP server + orchestrator in MOCK mode (no real API calls, no upload).
# Great for testing the whole pipeline before real credentials/videos exist.
YOUTUBE_MOCK=1
