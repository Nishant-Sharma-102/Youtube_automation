# Copy to documentary/.env and fill in real values. .env is git-ignored.
# This channel is SEPARATE from the kids and Hindi-history channels: its own
# Sheet, its own worksheet, its own notification creds.

# --- Claude (topic research with web search) ---
# Falls back to the repo-root .env if not set here, so you can reuse one key.
ANTHROPIC_API_KEY=
# Optional model override. Default is claude-opus-4-8 (best factual accuracy for
# a documentary channel). Set to claude-sonnet-5 to cut cost if you prefer.
DOC_ANTHROPIC_MODEL=claude-opus-4-8

# --- Google Sheet topic queue (separate from the other two channels) ---
# Spreadsheet ID = the long string in the Sheet URL between /d/ and /edit.
DOC_SHEET_ID=
# The tab/worksheet name inside that spreadsheet for this channel.
DOC_WORKSHEET=documentary

# --- Google auth — pick ONE (service account recommended for cron) ---
# Option A: a service-account JSON key. Enable the Google Sheets API on its
# project and SHARE the spreadsheet with its client_email (Editor). Falls back to
# GOOGLE_SERVICE_ACCOUNT_JSON from the root .env if unset.
DOC_SERVICE_ACCOUNT_JSON=
# Option B: an OAuth desktop client + a token you mint once from it.
DOC_OAUTH_CLIENT_JSON=./oauth-client.json
DOC_OAUTH_TOKEN_JSON=./token.json

# --- Notifications (all optional; prints to stdout if none configured) ---
# Telegram (tried first). Create a bot via @BotFather; get the chat id from
# https://api.telegram.org/bot<token>/getUpdates after messaging the bot.
TELEGRAM_DOC_BOT_TOKEN=
TELEGRAM_DOC_CHAT_ID=
# Email (tried second). Standard SMTP with STARTTLS.
DOC_SMTP_HOST=
DOC_SMTP_PORT=587
DOC_SMTP_USER=
DOC_SMTP_PASS=
DOC_EMAIL_TO=

# --- Language / localization ---
# This channel narrates in HINDI by default. DOC_NARRATION_LANGUAGE steers the
# Claude-written script + packaging (titles/description/tags/hashtags);
# DOC_LANGUAGE_CODE is the BCP-47 tag stamped on the YouTube upload. Set both back
# to "English" / "en" to revert to an English channel.
DOC_NARRATION_LANGUAGE=Hindi
DOC_LANGUAGE_CODE=hi

# --- Voice (Phase 4): ElevenLabs -> Google Cloud TTS -> Edge (free) ---
# ElevenLabs (PRIMARY). DOC_-prefixed vars win; otherwise the shared root-.env
# ELEVENLABS_* vars are used. Give THIS channel its own narrator voice id — the
# root ELEVENLABS_VOICE_ID is your other channels' voice. multilingual_v2 speaks
# Hindi natively; for the most authentic accent, set a Hindi ElevenLabs voice id
# here, or run gen_voice.py --provider edge to force the native Hindi Edge voice.
DOC_ELEVENLABS_API_KEY=
DOC_ELEVENLABS_VOICE_ID=
DOC_ELEVENLABS_MODEL=eleven_multilingual_v2
# Google Cloud TTS (fallback). Uses the same Google creds as the Sheet.
DOC_GOOGLE_TTS_VOICE=hi-IN-Neural2-B
# Edge TTS (free final fallback, no key). Native Hindi documentary voice.
# Tone: deep, warm, calm & suspenseful — pitched down + slowed. Make pitch MORE
# negative (e.g. -20Hz) for even deeper; less negative (-8Hz) for subtler.
DOC_EDGE_VOICE=hi-IN-MadhurNeural
DOC_EDGE_RATE=-12%
DOC_EDGE_PITCH=-15Hz

# --- Music (Phase 6) ---
# Source: "jamendo" (recommended — documented music API + per-track CC license) or
# "pixabay" (no public music API; effectively mock). Without a key the phase mocks.
DOC_MUSIC_SOURCE=jamendo
# Free client_id from https://developer.jamendo.com — enables real, previewable tracks.
=
# Monetized channel: drop NonCommercial (NC) + NoDerivatives (ND) tracks. Leave true.
DOC_MUSIC_REQUIRE_COMMERCIAL=true
# Pixabay music (only if your account has audio API access — usually not available).
DOC_PIXABAY_API_KEY=

# --- Phase 8 (thumbnails + metadata) ---
DOC_METADATA_MODEL=claude-opus-4-8
# Heavy/bold TTF for thumbnail text (must be installed).
DOC_THUMB_FONT=/usr/share/fonts/truetype/liberation2/LiberationSans-Bold.ttf
# Appended to every description's subscribe line.
DOC_UPLOAD_SCHEDULE=new documentaries every week

# --- Phase 9 (publishing) ---
# THIS channel's OWN YouTube OAuth2 refresh token — a THIRD, separate channel.
# Never the kids or history tokens. Mint via the YouTube MCP repo's youtube:auth
# while logged into the DOCUMENTARY channel's Google account.
YOUTUBE_DOCUMENTARY_CHANNEL_REFRESH_TOKEN=
# Default upload privacy (first real publish should stay private until verified).
DOC_PUBLISH_PRIVACY=private
# Notifications (clearly labeled "Documentary Channel").
TELEGRAM_DOC_BOT_TOKEN=
TELEGRAM_DOC_CHAT_ID=
