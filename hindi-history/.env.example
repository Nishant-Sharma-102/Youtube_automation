# Copy to hindi-history/.env and fill in real values. .env is git-ignored.
# THIS template must never contain real secrets.

# --- Gemini (Phase 1 script generation) ---
# Free-tier key from Google AI Studio: https://aistudio.google.com/app/apikey
# You may reuse the same key as the kids channel; put the value HERE, don't hardcode it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Google Sheets content queue (separate from the kids channel queue) ---
# The spreadsheet ID (the long string in the Sheet URL between /d/ and /edit).
HISTORY_SHEET_ID=
# A NEW tab/worksheet name inside that spreadsheet, dedicated to this channel.
HISTORY_WORKSHEET=hindi_history

# --- Google auth (Sheets + Cloud TTS) — pick ONE ---
# Option A (recommended, headless/cron): a service-account JSON key. Enable the
# Google Sheets API + Cloud Text-to-Speech API on its project, SHARE the sheet with
# its client_email (Editor). Leave the OAuth vars blank if you use this.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Option B: an OAuth client (desktop app). Point this at the client JSON, then run
# `python auth_setup.py` ONCE (browser) to create token.json. Cloud TTS also needs
# billing enabled on the project.
GOOGLE_OAUTH_CLIENT_JSON=./oauth-client.json
GOOGLE_OAUTH_TOKEN_JSON=./token.json
# Quota/billing project for Cloud TTS when using OAuth creds (defaults to the
# project_id inside the OAuth client JSON).
GOOGLE_CLOUD_PROJECT=

# --- Voice (Phase 2) ---
# Provider chain, tried in priority order:
#   ElevenLabs → Google Cloud TTS → Gemini TTS → Edge TTS
# The first configured provider that renders a scene is locked for the whole
# episode; the pipeline falls through to the next only if one fails. Edge TTS is
# free and needs no key, so it's the always-available final fallback.

# ElevenLabs (PRIMARY). Get a key at https://elevenlabs.io. Any multilingual
# voice speaks Hindi via eleven_multilingual_v2. Leave the key blank to skip it.
ELEVENLABS_API_KEY=
HISTORY_ELEVENLABS_VOICE_ID=
HISTORY_ELEVENLABS_MODEL=eleven_multilingual_v2

# Google Cloud TTS (fallback). hi-IN WaveNet (1M chars/mo free). Use a
# hi-IN-Standard-* voice for the 4M/mo tier. Auth via the Google creds above.
HISTORY_TTS_VOICE=hi-IN-Wavenet-A

# Edge TTS (free final fallback, no key). Optional voice/rate/pitch overrides:
# HISTORY_EDGE_VOICE=hi-IN-MadhurNeural
# HISTORY_EDGE_RATE=+9%
# HISTORY_EDGE_PITCH=-2Hz
